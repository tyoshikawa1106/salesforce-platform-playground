<?xml version="1.0" encoding="UTF-8" ?>
<Package xmlns="http://soap.sforce.com/2006/04/metadata">
    <!-- 認証 / セキュリティ -->
    <!-- 接続アプリケーション -->
    <types>
        <members>*</members>
        <name>ConnectedApp</name>
    </types>
    <!-- 外部クライアントアプリケーション -->
    <types>
        <members>*</members>
        <name>ExternalClientApplication</name>
