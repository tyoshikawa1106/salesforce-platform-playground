<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status__c</fullName>
    <description>スキャンの待機、処理中、完了、失敗の状態を保持する。</description>
    <inlineHelpText>スキャン開始後の現在状態を確認します。</inlineHelpText>
    <label>ステータス</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Pending</fullName>
                <default>true</default>
                <label>待機中</label>
            </value>
            <value>
                <fullName>Running</fullName>
                <default>false</default>
                <label>処理中</label>
            </value>
            <value>
                <fullName>Completed</fullName>
                <default>false</default>
                <label>完了</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>失敗</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
